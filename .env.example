# ShieldPilot Environment Configuration
# Copy to .env and customize for your deployment.
# The .env file is loaded automatically via python-dotenv (if installed).
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED - Security Secrets
# =============================================================================

# JWT secret key for authentication tokens (auto-generated if empty, but
# tokens will NOT persist across restarts). Use a 64+ char hex string.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SHIELDPILOT_SECRET_KEY=

# =============================================================================
# OPTIONAL - Super Admin Account
# =============================================================================

# Super admin with unlimited tier (bypasses all billing limits)
SHIELDPILOT_SUPER_ADMIN_EMAIL=
# bcrypt hash preferred (e.g. $2b$12$...); plaintext accepted with warning
SHIELDPILOT_SUPER_ADMIN_PASSWORD=
SHIELDPILOT_SUPER_ADMIN_USERNAME=

# Default admin password (legacy, prefer super admin above)
SHIELDPILOT_ADMIN_PASSWORD=

# =============================================================================
# OPTIONAL - Google OAuth
# =============================================================================

# Google OAuth credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Google client secret (either variable works, GOOGLE_CLIENT_SECRET is the standard name)
GOOGLE_CLIENT_SECRET=
# Alias (also accepted): SHIELDPILOT_GOOGLE_SECRET

# =============================================================================
# OPTIONAL - Email (SMTP)
# =============================================================================

# Gmail SMTP for password reset and verification emails
# Create an app password at: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# =============================================================================
# OPTIONAL - Stripe Billing
# =============================================================================

# Stripe API keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_

# Stripe webhook secret from https://dashboard.stripe.com/webhooks
# Or use Stripe CLI: stripe listen --forward-to localhost:8420/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs from https://dashboard.stripe.com/products
# Create two products: "ShieldPilot Pro" and "ShieldPilot Pro+"
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_ANNUAL=price_
STRIPE_PRICE_PRO_PLUS_MONTHLY=price_
STRIPE_PRICE_PRO_PLUS_ANNUAL=price_

# Legacy price IDs (optional — old enterprise/unlimited mapped to pro_plus)
# STRIPE_PRICE_UNLIMITED_MONTHLY=price_
# STRIPE_PRICE_UNLIMITED_ANNUAL=price_

# =============================================================================
# OPTIONAL - Operating Mode
# =============================================================================

# Operating mode: enforce | audit | disabled
SENTINEL_MODE=enforce

# Database path (default: sentinel.db)
SENTINEL_DB=sentinel.db

# Custom path to sentinel.yaml (optional, auto-discovered if not set)
SENTINEL_CONFIG=

# Enable LLM-powered analysis (requires ANTHROPIC_API_KEY)
SENTINEL_LLM_ENABLED=false

# Anthropic API key for LLM analysis
ANTHROPIC_API_KEY=

# =============================================================================
# OPTIONAL - CORS
# =============================================================================

# Comma-separated allowed CORS origins (default: localhost)
SHIELDPILOT_CORS_ORIGINS=http://localhost:8420,http://127.0.0.1:8420

# =============================================================================
# OPTIONAL - Legal / Impressum
# =============================================================================

# Company details for Impressum page (required for German law)
SHIELDPILOT_COMPANY_NAME=
SHIELDPILOT_CONTACT_EMAIL=

# =============================================================================
# OPTIONAL - ML / Active Learning
# =============================================================================

# Path for active learning JSONL log (optional, for retraining)
SENTINEL_ACTIVE_LEARNING_PATH=

# ML mode: disabled | shadow | enforce
SENTINEL_ML_MODE=disabled
