{
  "name": "shieldpilot",
  "displayName": "ShieldPilot Security Guard",
  "version": "0.1.0",
  "description": "Real-time security monitoring for Claude Code. Scans every tool call through a risk engine, prompt injection scanner, and ML classifier before execution.",
  "author": "ShieldPilot Team",
  "license": "MIT",
  "homepage": "https://github.com/maxwalser001-del/Cyber-Security-",
  "repository": "https://github.com/maxwalser001-del/Cyber-Security-",
  "keywords": [
    "security",
    "ai-safety",
    "prompt-injection",
    "risk-engine",
    "claude-code"
  ],
  "engines": {
    "claude-code": ">=1.0.0"
  },
  "platform": ["darwin", "linux"],
  "pythonVersion": ">=3.9",
  "hooks": {
    "PreToolUse": {
      "command": "plugin/claude-code/hook.sh",
      "timeout": 10,
      "description": "ShieldPilot risk assessment on every tool call"
    }
  },
  "permissions": [
    "stdin:read",
    "stdout:write",
    "filesystem:read",
    "network:none"
  ],
  "configuration": {
    "configFile": "sentinel.yaml",
    "description": "ShieldPilot configuration file (risk thresholds, billing, auth, etc.)"
  },
  "capabilities": [
    "risk-scoring",
    "prompt-injection-detection",
    "ml-classification",
    "audit-logging",
    "protected-path-enforcement",
    "rate-limiting"
  ]
}
